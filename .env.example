VITE_SUPABASE_URL=https://your-project-id.supabase.co
# Use the anon key from Supabase > Project Settings > API
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_API_URL=http://localhost:3001

# Blog auto-publishing
WORDPRESS_BASE_URL=https://lumivids.com/blog
WORDPRESS_USERNAME=your_wordpress_username
WORDPRESS_APP_PASSWORD=your_wordpress_application_password
BLOG_XLSX_PATH=textos.xlsx
BLOG_DRY_RUN=true

# Optional: only needed when planilha rows do not include content/text
BLOG_OPENAI_API_KEY=
BLOG_OPENAI_MODEL=gpt-4.1-mini
BLOG_OPENAI_URL=https://api.openai.com/v1/chat/completions
