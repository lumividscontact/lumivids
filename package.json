{
  "name": "lumivids",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run sync:sitemap && vite build && npm run copy:htaccess",
    "build:check": "tsc -b && npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "sync:sitemap": "tsx scripts/update-sitemap.ts",
    "copy:htaccess": "node scripts/copy-htaccess.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:i18n": "tsx scripts/validate-i18n.ts",
    "sync:credit-costs": "tsx scripts/sync-credit-costs.ts",
    "build:with-sync": "npm run sync:credit-costs && npm run build",
    "blog:publish": "tsx scripts/publish-blog-from-xlsx.ts",
    "blog:generate": "tsx scripts/generate-articles-local.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.7.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^3.2.4"
  }
}
